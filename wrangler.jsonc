{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "verrio-maps-workspace",
  "compatibility_date": "2026-04-28",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "deploy-root"
  },
  "routes": [
    {
      "pattern": "maps.verrio.co/*",
      "zone_name": "verrio.co"
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
